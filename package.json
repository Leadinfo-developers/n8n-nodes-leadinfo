{
	"name": "n8n-nodes-leadinfo",
	"version": "1.0.4",
	"description": "n8n node for Leadinfo — trigger workflows when Leadinfo identifies a company or contact on your website",
	"license": "MIT",
	"homepage": "https://github.com/Leadinfo-developers/n8n-nodes-leadinfo",
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"n8n-community-node-package",
		"leadinfo",
		"lead-generation",
		"website-visitors"
	],
	"author": {
		"name": "Leadinfo",
		"email": "developers@leadinfo.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Leadinfo-developers/n8n-nodes-leadinfo"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"dev:local": "n8n-node dev --external-n8n",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": false,
		"credentials": [
			"dist/credentials/LeadinfoOAuth2Api.credentials.js"
		],
		"nodes": [
			"dist/nodes/LeadinfoTriggerCompany/LeadinfoTriggerCompany.node.js",
			"dist/nodes/LeadinfoTriggerContact/LeadinfoTriggerContact.node.js",
			"dist/nodes/LeadinfoShareCompany/LeadinfoShareCompany.node.js",
			"dist/nodes/LeadinfoShareContact/LeadinfoShareContact.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.39.4",
		"n8n-workflow": "^2.16.0",
		"prettier": "3.8.3",
		"release-it": "20.2.0",
		"typescript": "6.0.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
